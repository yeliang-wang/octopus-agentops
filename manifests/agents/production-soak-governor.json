{
  "schema": "agent-octopus-agent/v1",
  "id": "production-soak-governor",
  "version": "1.0.0",
  "lifecycle": "experimental",
  "pluginId": "production-soak",
  "category": "production-validation",
  "source": {
    "claudeMarkdown": "agents/production-soak-governor.md"
  },
  "distributions": {
    "codexToml": "integrations/codex/agents/production-soak-governor.toml"
  },
  "native": {
    "model": "default",
    "tools": [
      "shell",
      "filesystem",
      "scm",
      "ci"
    ],
    "disallowedTools": [
      "mock-production-soak"
    ],
    "skills": [
      "agency-evidence-collector",
      "agency-software-architect"
    ],
    "memory": "project-and-user",
    "hooks": [],
    "allowedSpawnAgents": []
  },
  "purpose": "Generic production-like long-duration soak governance for agent products using real services, real external boundaries, periodic reporting, and product-gap blocking.",
  "boundaries": {
    "allowed": [
      "Discover product services and health checks",
      "Verify clean baseline readiness",
      "Run non-mock precheck",
      "Start durable long-running validation sessions",
      "Report periodic evidence and product gaps"
    ],
    "forbidden": [
      "Claim production-grade success with mock dependencies",
      "Use chat-agent manual repair as product runtime capability",
      "Print secrets",
      "Continue formal soak through a product-grade blocker"
    ]
  },
  "inputs": [
    "product root",
    "duration hours",
    "report interval",
    "run mode",
    "data root",
    "service inventory",
    "health checks",
    "traffic generators",
    "lifecycle runner",
    "acceptance criteria"
  ],
  "outputs": [
    "readiness result",
    "clean baseline result",
    "non-mock precheck result",
    "periodic status reports",
    "product gap report",
    "final soak evidence report"
  ],
  "evidence": [
    "health checks",
    "traffic counts",
    "LLM trace/provider/model",
    "SCM branch or MR/PR",
    "CI/CD job status",
    "logs and artifacts"
  ],
  "confirmationGates": [
    "long-run start readiness",
    "data cleanup scope",
    "SCM/MR/PR action",
    "release or publish action"
  ],
  "dangerousActions": [
    "data reset",
    "service stop",
    "long-running process start",
    "code upgrade",
    "release"
  ],
  "validation": {
    "requiredSections": [
      "Mission",
      "Non-Negotiable Production Rule",
      "Readiness Gate",
      "Clean Baseline Protocol",
      "Non-Mock Precheck",
      "Periodic Reporting",
      "Final Report"
    ],
    "requiredPhrases": [
      "Do not use mock",
      "BLOCKED: production soak is not ready",
      "Never report that 24h is running"
    ]
  }
}
