{
  "schema": "agent-octopus-agent/v1",
  "id": "user-flow-debug",
  "version": "1.0.0",
  "lifecycle": "beta",
  "pluginId": "mcp-e2e-governance",
  "category": "dashboard-e2e",
  "source": {
    "claudeMarkdown": "agents/user-flow-debug.md"
  },
  "distributions": {
    "codexToml": "integrations/codex/agents/user-flow-debug.toml"
  },
  "native": {
    "model": "default",
    "tools": [
      "shell",
      "browser",
      "filesystem"
    ],
    "disallowedTools": [
      "direct-product-api-for-user-journey",
      "non-production-release-evidence"
    ],
    "skills": [
      "browser:control-in-app-browser"
    ],
    "memory": "project",
    "hooks": [],
    "allowedSpawnAgents": []
  },
  "purpose": "Real Dashboard user-flow debugging for agent applications with browser evidence, runtime-flow discovery, artifact validation, and controlled fixes.",
  "boundaries": {
    "allowed": [
      "Operate the specified Dashboard entry UI",
      "Classify runtime flow from visible UI and runtime contract",
      "Capture screenshots and artifacts",
      "Diagnose smallest failing runtime boundary",
      "Apply fixes only under the selected fix policy"
    ],
    "forbidden": [
      "Bypass the product UI for normal user journey execution",
      "Invent business content or fake artifacts",
      "Escalate from diagnosis to code changes silently",
      "Create ad hoc diagnostic scripts in target workspaces",
      "Use mock, fake, stub, simulator, fixture-only, demo-only, smoke-only, or chat-only evidence as production release evidence"
    ]
  },
  "inputs": [
    "run target",
    "goal",
    "loop cadence",
    "stop condition",
    "domain id",
    "scenario id or name",
    "Dashboard entry UI",
    "attachment policy",
    "Dashboard URL or local ports",
    "MCP/JDBC mode",
    "run mode",
    "screenshot directory",
    "fix policy"
  ],
  "outputs": [
    "Dashboard route tested",
    "loop state",
    "iteration report",
    "run id",
    "screenshot directory",
    "artifact summary",
    "runtime flow type",
    "step validation matrix",
    "fix summary"
  ],
  "evidence": [
    "browser screenshots",
    "per-iteration evidence",
    "runtime responses",
    "artifact files",
    "logs",
    "sandbox health-check",
    "sandbox find-artifacts"
  ],
  "confirmationGates": [
    "missing entry UI",
    "ambiguous runtime flow",
    "runtime-fix",
    "code-fix",
    "module-update",
    "internal tick API"
  ],
  "dangerousActions": [
    "deployed module update",
    "runtime restart",
    "code modification",
    "internal scheduler tick"
  ],
  "loopContract": {
    "enabled": true,
    "evidenceRequired": true,
    "confirmationGatesPreserved": true,
    "inputs": [
      "goal",
      "runTarget",
      "loopCadence",
      "stopCondition",
      "dashboardEntryUi",
      "fixPolicy",
      "finalGoal",
      "phaseGoals",
      "acceptanceCriteria",
      "reportCadence",
      "finalDecision"
    ],
    "stateFields": [
      "goal",
      "finalGoal",
      "phaseGoals",
      "currentPhase",
      "acceptanceCriteria",
      "reportCadence",
      "finalDecision",
      "attempt",
      "runTarget",
      "runtimeFlowType",
      "lastScreenshotDirectory",
      "lastArtifacts",
      "lastFailureBoundary",
      "lastFix",
      "blocker",
      "nextAction",
      "stopCondition"
    ],
    "stopPolicies": [
      "flow_passes",
      "maximum_attempts",
      "deadline",
      "ambiguous_ui_contract",
      "required_user_choice",
      "fix_policy_boundary",
      "explicit_user_stop"
    ],
    "cadenceModes": [
      "continuous",
      "after_each_fix",
      "fixed_interval",
      "user_checkpoint"
    ],
    "iterationEvidence": [
      "browser screenshots",
      "runtime responses",
      "artifact files",
      "logs",
      "step validation matrix"
    ],
    "goalWindow": {
      "required": true,
      "fields": [
        "finalGoal",
        "phaseGoals",
        "currentPhase",
        "acceptanceCriteria",
        "reportCadence",
        "finalDecision"
      ],
      "phaseGoalRequired": true,
      "finalGoalRequired": true,
      "acceptanceCriteriaRequired": true,
      "finalDecisionRequired": true
    }
  },
  "runtimeAdapters": {
    "codexGoal": {
      "supported": true,
      "outerGoal": "Prove the visible Dashboard user flow through browser evidence without bypassing the UI journey.",
      "innerLoopAgent": "user-flow-debug",
      "stateArtifact": "data/user-flow-debug/<projectId>/loop-state.json",
      "statusArtifact": "data/user-flow-debug/<projectId>/current-status.md",
      "evidenceRoot": "data/user-flow-debug/<projectId>/evidence/",
      "requiresFeature": "goals",
      "resumePolicy": "Resume only after Dashboard reachability and runtime flow type are rechecked."
    },
    "shellRunner": {
      "supported": true,
      "stateArtifact": "data/user-flow-debug/<projectId>/loop-state.json"
    }
  },
  "validation": {
    "requiredSections": [
      "Toolkit-Wide Production Release Rule",
      "Required Inputs",
      "Runtime Flow Discovery",
      "No Built-In Scenario Defaults",
      "Goal-Driven Loop Mode",
      "Non-Negotiable Rules",
      "Workflow",
      "Final Report",
      "Loop Goal Window"
    ],
    "requiredPhrases": [
      "Use real Dashboard UI browser automation",
      "Runtime flow type",
      "Do not create temporary Python diagnostic files",
      "loopState",
      "stopCondition",
      "Smoke checks may prove connectivity only",
      "NO-GO",
      "product-native release evidence",
      "finalGoal",
      "phaseGoals",
      "acceptanceCriteria",
      "finalDecision"
    ]
  }
}
