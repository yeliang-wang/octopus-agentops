{
  "schema": "agent-octopus-agent/v1",
  "id": "user-flow-debug",
  "version": "1.0.0",
  "lifecycle": "beta",
  "pluginId": "mcp-e2e-governance",
  "category": "dashboard-e2e",
  "source": {
    "claudeMarkdown": "agents/user-flow-debug.md"
  },
  "distributions": {
    "codexToml": "integrations/codex/agents/user-flow-debug.toml"
  },
  "native": {
    "model": "default",
    "tools": [
      "shell",
      "browser",
      "filesystem"
    ],
    "disallowedTools": [
      "direct-product-api-for-user-journey",
      "non-production-release-evidence"
    ],
    "skills": [
      "browser:control-in-app-browser"
    ],
    "memory": "project",
    "hooks": [],
    "allowedSpawnAgents": []
  },
  "purpose": "Real Dashboard user-flow debugging for agent applications with browser evidence, runtime-flow discovery, artifact validation, and controlled fixes.",
  "boundaries": {
    "allowed": [
      "Operate the specified Dashboard entry UI",
      "Classify runtime flow from visible UI and runtime contract",
      "Capture screenshots and artifacts",
      "Diagnose smallest failing runtime boundary",
      "Apply fixes only under the selected fix policy"
    ],
    "forbidden": [
      "Bypass the product UI for normal user journey execution",
      "Invent business content or fake artifacts",
      "Escalate from diagnosis to code changes silently",
      "Create ad hoc diagnostic scripts in target workspaces",
      "Use mock, fake, stub, simulator, fixture-only, demo-only, smoke-only, or chat-only evidence as production release evidence"
    ]
  },
  "inputs": [
    "run target",
    "goal",
    "loop cadence",
    "stop condition",
    "domain id",
    "scenario id or name",
    "Dashboard entry UI",
    "attachment policy",
    "Dashboard URL or local ports",
    "MCP/JDBC mode",
    "run mode",
    "screenshot directory",
    "fix policy"
  ],
  "outputs": [
    "Dashboard route tested",
    "loop state",
    "iteration report",
    "run id",
    "screenshot directory",
    "artifact summary",
    "runtime flow type",
    "step validation matrix",
    "fix summary",
    "coverage matrix result",
    "repair verification result",
    "per-phase decision chain"
  ],
  "evidence": [
    "browser screenshots",
    "per-iteration evidence",
    "runtime responses",
    "artifact files",
    "logs",
    "sandbox health-check",
    "sandbox find-artifacts",
    "coverage matrix status",
    "repair verification evidence",
    "per-phase decision chain"
  ],
  "confirmationGates": [
    "missing entry UI",
    "ambiguous runtime flow",
    "runtime-fix",
    "code-fix",
    "module-update",
    "internal tick API"
  ],
  "dangerousActions": [
    "deployed module update",
    "runtime restart",
    "code modification",
    "internal scheduler tick"
  ],
  "loopContract": {
    "enabled": true,
    "evidenceRequired": true,
    "confirmationGatesPreserved": true,
    "inputs": [
      "goal",
      "runTarget",
      "loopCadence",
      "stopCondition",
      "dashboardEntryUi",
      "fixPolicy",
      "finalGoal",
      "phaseGoals",
      "acceptanceCriteria",
      "targetPlan",
      "targetPlanConfirmation",
      "reportCadence",
      "finalDecision",
      "coverageMatrix",
      "iterationPlan",
      "evidenceMap",
      "blockerPolicy",
      "repairPolicy",
      "releaseDecision",
      "decisionChain"
    ],
    "stateFields": [
      "goal",
      "finalGoal",
      "phaseGoals",
      "currentPhase",
      "acceptanceCriteria",
      "targetPlan",
      "targetPlanConfirmation",
      "reportCadence",
      "finalDecision",
      "attempt",
      "runTarget",
      "runtimeFlowType",
      "lastScreenshotDirectory",
      "lastArtifacts",
      "lastFailureBoundary",
      "lastFix",
      "blocker",
      "nextAction",
      "stopCondition",
      "coverageMatrix",
      "iterationPlan",
      "evidenceMap",
      "blockerPolicy",
      "repairPolicy",
      "releaseDecision",
      "decisionChain",
      "artifactIndex",
      "stateSizeGuard"
    ],
    "stopPolicies": [
      "flow_passes",
      "maximum_attempts",
      "deadline",
      "ambiguous_ui_contract",
      "required_user_choice",
      "fix_policy_boundary",
      "explicit_user_stop",
      "coverage_matrix_complete",
      "repeated_blocker_requires_repair",
      "pending_target_plan_confirmation"
    ],
    "cadenceModes": [
      "continuous",
      "after_each_fix",
      "fixed_interval",
      "user_checkpoint"
    ],
    "iterationEvidence": [
      "browser screenshots",
      "runtime responses",
      "artifact files",
      "logs",
      "step validation matrix",
      "coverage matrix status",
      "repair verification evidence",
      "per-phase decision chain",
      "iteration artifact references",
      "state size guard result"
    ],
    "goalWindow": {
      "required": true,
      "fields": [
        "finalGoal",
        "phaseGoals",
        "currentPhase",
        "acceptanceCriteria",
        "targetPlan",
        "targetPlanConfirmation",
        "reportCadence",
        "finalDecision"
      ],
      "phaseGoalRequired": true,
      "finalGoalRequired": true,
      "acceptanceCriteriaRequired": true,
      "finalDecisionRequired": true,
      "confirmBeforeLoop": true,
      "targetPlanRequired": true,
      "targetPlanConfirmationRequired": true
    },
    "coverageMatrix": {
      "required": true,
      "fields": [
        "capability",
        "scenario",
        "connectedProject",
        "requiredEvidence",
        "status",
        "blocker",
        "nextRepairAction"
      ],
      "statusValues": [
        "PASS",
        "FAIL",
        "NOT_RUN",
        "NOT_APPLICABLE",
        "BLOCKED"
      ],
      "minimumRows": 1,
      "repairRequiredOnRepeatBlocker": true
    },
    "repairPolicy": {
      "required": true,
      "repeatedBlockerThreshold": 2,
      "actions": [
        "diagnose",
        "repair",
        "verify",
        "escalate",
        "stop_blocked"
      ],
      "stopOnUnrepairable": true
    },
    "decisionChain": {
      "required": true,
      "fields": [
        "phase",
        "evidence",
        "rule",
        "options",
        "decision",
        "rationale",
        "nextAction"
      ],
      "perPhaseRequired": true,
      "printRequired": true
    }
  },
  "runtimeAdapters": {
    "codexGoal": {
      "supported": true,
      "outerGoal": "Prove the visible Dashboard user flow through browser evidence without bypassing the UI journey.",
      "innerLoopAgent": "user-flow-debug",
      "stateArtifact": "data/user-flow-debug/<projectId>/loop-state.json",
      "statusArtifact": "data/user-flow-debug/<projectId>/current-status.md",
      "evidenceRoot": "data/user-flow-debug/<projectId>/evidence/",
      "requiresFeature": "goals",
      "resumePolicy": "Resume only after Dashboard reachability and runtime flow type are rechecked."
    },
    "shellRunner": {
      "supported": true,
      "stateArtifact": "data/user-flow-debug/<projectId>/loop-state.json"
    }
  },
  "validation": {
    "requiredSections": [
      "Platform-Wide Production Release Rule",
      "Required Inputs",
      "Runtime Flow Discovery",
      "No Built-In Scenario Defaults",
      "Goal-Driven Loop Mode",
      "Non-Negotiable Rules",
      "Workflow",
      "Final Report",
      "Loop Goal Window",
      "Release Coverage Matrix Loop",
      "Production Representative Sandbox"
    ],
    "requiredPhrases": [
      "Use real Dashboard UI browser automation",
      "Runtime flow type",
      "Do not create temporary Python diagnostic files",
      "loopState",
      "stopCondition",
      "Smoke checks may prove connectivity only",
      "NO-GO",
      "product-native release evidence",
      "finalGoal",
      "phaseGoals",
      "acceptanceCriteria",
      "finalDecision",
      "coverageMatrix",
      "evidenceMap",
      "repairPolicy",
      "releaseDecision",
      "repeated blocker",
      "decisionChain",
      "per-phase decision chain",
      "阶段决策链",
      "Production Representative Sandbox",
      "production-representative/manifest.json",
      "real target-product registration",
      "summary state only",
      "externalized to iteration artifacts",
      "state size guard",
      "target plan confirmation",
      "explicit user confirmation before entering the loop",
      "BLOCKED: pending loop target plan confirmation"
    ]
  }
}
