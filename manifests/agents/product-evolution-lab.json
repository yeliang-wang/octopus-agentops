{
  "schema": "agent-octopus-agent/v1",
  "id": "product-evolution-lab",
  "version": "1.0.0",
  "lifecycle": "beta",
  "pluginId": "product-evolution-lab",
  "category": "product-evolution",
  "source": {
    "claudeMarkdown": "agents/product-evolution-lab.md"
  },
  "distributions": {
    "codexToml": "integrations/codex/agents/product-evolution-lab.toml"
  },
  "native": {
    "model": "default",
    "tools": [
      "shell",
      "browser",
      "mcp",
      "filesystem",
      "scm"
    ],
    "disallowedTools": [
      "production-customer-traffic",
      "protected-asset-mutation",
      "non-production-release-evidence"
    ],
    "skills": [
      "agency-software-architect",
      "agency-evidence-collector"
    ],
    "memory": "project-and-user",
    "hooks": [],
    "allowedSpawnAgents": [
      "mcp-e2e-governor",
      "user-flow-debug",
      "production-lifecycle-governor"
    ]
  },
  "purpose": "Generic dev-stage product evolution lab for rotating authorized materials, running product E2E pressure, collecting evidence, triggering improvement workflows, and validating human review closure.",
  "boundaries": {
    "allowed": [
      "Operate as an external lab agent",
      "Use product-approved UI/API/MCP/CLI entrypoints",
      "Maintain toolkit-managed lab storage",
      "Trigger configured improvement evidence submission",
      "Simulate or verify human review closure"
    ],
    "forbidden": [
      "Become part of the target product production runtime",
      "Modify protected product assets without explicit approval",
      "Merge SCM change requests",
      "Publish lifecycle changes without explicit confirmation",
      "Use production customer traffic",
      "Use mock, fake, stub, simulator, fixture-only, demo-only, smoke-only, or chat-only evidence as production release evidence"
    ]
  },
  "inputs": [
    "goal",
    "product root",
    "product profile",
    "runtime target",
    "loop cadence",
    "stop condition",
    "entrypoints and health checks",
    "material paths or public material authorization",
    "publish policy",
    "fix policy"
  ],
  "outputs": [
    "current status file",
    "latest run link",
    "loop state",
    "iteration report",
    "run summary",
    "E2E results",
    "improvement workflow result",
    "user-flow results",
    "screenshots",
    "report",
    "coverage matrix result",
    "repair verification result",
    "per-phase decision chain"
  ],
  "evidence": [
    "per-iteration evidence",
    "UI/API/MCP/CLI calls",
    "service responses",
    "execution traces",
    "model or tool traces",
    "review screenshots",
    "evidence bundle",
    "improvement opportunity",
    "proposal or plan",
    "coverage matrix status",
    "repair verification evidence",
    "per-phase decision chain"
  ],
  "confirmationGates": [
    "public material authorization",
    "SCM change request creation",
    "publish",
    "rollback",
    "destroy",
    "source mutation",
    "protected asset mutation"
  ],
  "dangerousActions": [
    "SCM change request creation",
    "lifecycle publish",
    "lifecycle rollback",
    "lifecycle destroy",
    "source code mutation"
  ],
  "loopContract": {
    "enabled": true,
    "evidenceRequired": true,
    "confirmationGatesPreserved": true,
    "inputs": [
      "goal",
      "materialPolicy",
      "runtimeTarget",
      "loopCadence",
      "stopCondition",
      "publishPolicy",
      "fixPolicy",
      "finalGoal",
      "phaseGoals",
      "acceptanceCriteria",
      "targetPlan",
      "targetPlanConfirmation",
      "reportCadence",
      "finalDecision",
      "coverageMatrix",
      "iterationPlan",
      "evidenceMap",
      "blockerPolicy",
      "repairPolicy",
      "releaseDecision",
      "decisionChain"
    ],
    "stateFields": [
      "goal",
      "finalGoal",
      "phaseGoals",
      "currentPhase",
      "acceptanceCriteria",
      "targetPlan",
      "targetPlanConfirmation",
      "reportCadence",
      "finalDecision",
      "round",
      "material",
      "runtimeTarget",
      "readiness",
      "e2eResult",
      "productGapSignals",
      "improvementResult",
      "reviewState",
      "blocker",
      "nextAction",
      "stopCondition",
      "coverageMatrix",
      "iterationPlan",
      "evidenceMap",
      "blockerPolicy",
      "repairPolicy",
      "releaseDecision",
      "decisionChain",
      "artifactIndex",
      "stateSizeGuard"
    ],
    "stopPolicies": [
      "goal_proven",
      "product_grade_blocker",
      "maximum_rounds",
      "deadline",
      "missing_readiness",
      "unsafe_protected_path_mutation",
      "explicit_user_stop",
      "coverage_matrix_complete",
      "repeated_blocker_requires_repair",
      "pending_target_plan_confirmation"
    ],
    "cadenceModes": [
      "always_on_interval",
      "fixed_round_count",
      "fixed_duration",
      "user_checkpoint"
    ],
    "iterationEvidence": [
      "readiness result",
      "UI/API/MCP/CLI calls",
      "run artifacts",
      "product gap evidence",
      "review closure evidence",
      "coverage matrix status",
      "repair verification evidence",
      "per-phase decision chain",
      "iteration artifact references",
      "state size guard result"
    ],
    "goalWindow": {
      "required": true,
      "fields": [
        "finalGoal",
        "phaseGoals",
        "currentPhase",
        "acceptanceCriteria",
        "targetPlan",
        "targetPlanConfirmation",
        "reportCadence",
        "finalDecision"
      ],
      "phaseGoalRequired": true,
      "finalGoalRequired": true,
      "acceptanceCriteriaRequired": true,
      "finalDecisionRequired": true,
      "confirmBeforeLoop": true,
      "targetPlanRequired": true,
      "targetPlanConfirmationRequired": true
    },
    "coverageMatrix": {
      "required": true,
      "fields": [
        "capability",
        "scenario",
        "connectedProject",
        "requiredEvidence",
        "status",
        "blocker",
        "nextRepairAction"
      ],
      "statusValues": [
        "PASS",
        "FAIL",
        "NOT_RUN",
        "NOT_APPLICABLE",
        "BLOCKED"
      ],
      "minimumRows": 1,
      "repairRequiredOnRepeatBlocker": true
    },
    "repairPolicy": {
      "required": true,
      "repeatedBlockerThreshold": 2,
      "actions": [
        "diagnose",
        "repair",
        "verify",
        "escalate",
        "stop_blocked"
      ],
      "stopOnUnrepairable": true
    },
    "decisionChain": {
      "required": true,
      "fields": [
        "phase",
        "evidence",
        "rule",
        "options",
        "decision",
        "rationale",
        "nextAction"
      ],
      "perPhaseRequired": true,
      "printRequired": true
    }
  },
  "runtimeAdapters": {
    "codexGoal": {
      "supported": true,
      "outerGoal": "Pressure-test and evolve the target product through approved closed-loop entrypoints.",
      "innerLoopAgent": "product-evolution-lab",
      "stateArtifact": "data/product-evolution-lab/<projectId>/loop-state.json",
      "statusArtifact": "data/product-evolution-lab/<projectId>/current-status.md",
      "evidenceRoot": "data/product-evolution-lab/<projectId>/evidence/",
      "requiresFeature": "goals",
      "resumePolicy": "Resume only after readiness is current and stop on product-grade blockers or missing confirmation gates."
    },
    "shellRunner": {
      "supported": true,
      "stateArtifact": "data/product-evolution-lab/<projectId>/loop-state.json"
    }
  },
  "validation": {
    "requiredSections": [
      "Platform-Wide Production Release Rule",
      "Core Boundary",
      "Product Profile",
      "Protected Asset Boundary",
      "Persistent Chat Reporting",
      "Required Production-Closed-Loop Readiness",
      "Goal-Driven Loop Mode",
      "Standard Workflow",
      "Safety Rules",
      "Final Response Shape",
      "Loop Goal Window",
      "Release Coverage Matrix Loop",
      "Production Representative Sandbox"
    ],
    "requiredPhrases": [
      "BLOCKED: product closed loop is not ready",
      "loopState",
      "stopCondition",
      "current-status.md",
      "Do not use this lab agent against production customer traffic",
      "Smoke checks may prove connectivity only",
      "NO-GO",
      "product-native release evidence",
      "finalGoal",
      "phaseGoals",
      "acceptanceCriteria",
      "finalDecision",
      "coverageMatrix",
      "evidenceMap",
      "repairPolicy",
      "releaseDecision",
      "repeated blocker",
      "decisionChain",
      "per-phase decision chain",
      "阶段决策链",
      "Production Representative Sandbox",
      "production-representative/manifest.json",
      "real target-product registration",
      "summary state only",
      "externalized to iteration artifacts",
      "state size guard",
      "target plan confirmation",
      "explicit user confirmation before entering the loop",
      "BLOCKED: pending loop target plan confirmation"
    ]
  }
}
