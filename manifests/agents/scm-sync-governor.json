{
  "schema": "agent-octopus-agent/v1",
  "id": "scm-sync-governor",
  "version": "1.0.0",
  "lifecycle": "beta",
  "pluginId": "git-workflow",
  "category": "scm-governance",
  "source": {
    "claudeMarkdown": "agents/scm-sync-governor.md"
  },
  "distributions": {
    "codexToml": "integrations/codex/agents/scm-sync-governor.toml"
  },
  "native": {
    "model": "default",
    "tools": [
      "shell",
      "git"
    ],
    "disallowedTools": [
      "destructive-git-without-confirmation",
      "non-production-release-evidence"
    ],
    "skills": [],
    "memory": "project",
    "hooks": [],
    "allowedSpawnAgents": []
  },
  "purpose": "Safe SCM-oriented repository synchronization, commit, push, pull request or merge request, CI, and conflict workflow governance.",
  "boundaries": {
    "allowed": [
      "Inspect git repository state",
      "Fetch and merge remote branches",
      "Stage and commit intentional local changes",
      "Push only when requested or clearly implied",
      "Diagnose repository-host CI and change request state"
    ],
    "forbidden": [
      "Discard local work without explicit approval",
      "Force push without explicit approval",
      "Push directly to protected base branches without explicit approval",
      "Bypass hooks without explicit approval",
      "Use mock, fake, stub, simulator, fixture-only, demo-only, smoke-only, or chat-only evidence as production release evidence"
    ]
  },
  "inputs": [
    "target branch",
    "goal",
    "loop cadence",
    "stop condition",
    "sync direction",
    "local change policy",
    "divergence policy"
  ],
  "outputs": [
    "repository inspection summary",
    "loop state",
    "iteration report",
    "sync result",
    "commit and push summary",
    "CI or merge request status",
    "coverage matrix result",
    "repair verification result",
    "per-phase decision chain"
  ],
  "evidence": [
    "git status",
    "git log",
    "per-iteration evidence",
    "sandbox git-inspect",
    "sandbox git-commit-check",
    "sandbox git-conflicts",
    "coverage matrix status",
    "repair verification evidence",
    "per-phase decision chain"
  ],
  "confirmationGates": [
    "protected branch push",
    "force push",
    "destructive git commands",
    "branch ambiguity"
  ],
  "dangerousActions": [
    "git reset --hard",
    "git checkout -- <file>",
    "git clean",
    "git push --force",
    "branch deletion"
  ],
  "loopContract": {
    "enabled": true,
    "evidenceRequired": true,
    "confirmationGatesPreserved": true,
    "inputs": [
      "goal",
      "targetRef",
      "loopCadence",
      "stopCondition",
      "actionPolicy",
      "finalGoal",
      "phaseGoals",
      "acceptanceCriteria",
      "reportCadence",
      "finalDecision",
      "coverageMatrix",
      "iterationPlan",
      "evidenceMap",
      "blockerPolicy",
      "repairPolicy",
      "releaseDecision",
      "decisionChain"
    ],
    "stateFields": [
      "goal",
      "finalGoal",
      "phaseGoals",
      "currentPhase",
      "acceptanceCriteria",
      "reportCadence",
      "finalDecision",
      "targetRef",
      "currentBranch",
      "remoteState",
      "dirtyState",
      "lastAction",
      "lastEvidence",
      "blocker",
      "nextAction",
      "stopCondition",
      "coverageMatrix",
      "iterationPlan",
      "evidenceMap",
      "blockerPolicy",
      "repairPolicy",
      "releaseDecision",
      "decisionChain"
    ],
    "stopPolicies": [
      "goal_reached",
      "conflict_requires_user_choice",
      "ci_terminal_failure",
      "maximum_attempts",
      "deadline",
      "explicit_user_stop",
      "coverage_matrix_complete",
      "repeated_blocker_requires_repair"
    ],
    "cadenceModes": [
      "continuous",
      "user_checkpoint",
      "fixed_interval"
    ],
    "iterationEvidence": [
      "git status",
      "git log",
      "remote ref state",
      "CI or change request status",
      "command output",
      "coverage matrix status",
      "repair verification evidence",
      "per-phase decision chain"
    ],
    "goalWindow": {
      "required": true,
      "fields": [
        "finalGoal",
        "phaseGoals",
        "currentPhase",
        "acceptanceCriteria",
        "reportCadence",
        "finalDecision"
      ],
      "phaseGoalRequired": true,
      "finalGoalRequired": true,
      "acceptanceCriteriaRequired": true,
      "finalDecisionRequired": true
    },
    "coverageMatrix": {
      "required": true,
      "fields": [
        "capability",
        "scenario",
        "connectedProject",
        "requiredEvidence",
        "status",
        "blocker",
        "nextRepairAction"
      ],
      "statusValues": [
        "PASS",
        "FAIL",
        "NOT_RUN",
        "NOT_APPLICABLE",
        "BLOCKED"
      ],
      "minimumRows": 1,
      "repairRequiredOnRepeatBlocker": true
    },
    "repairPolicy": {
      "required": true,
      "repeatedBlockerThreshold": 2,
      "actions": [
        "diagnose",
        "repair",
        "verify",
        "escalate",
        "stop_blocked"
      ],
      "stopOnUnrepairable": true
    },
    "decisionChain": {
      "required": true,
      "fields": [
        "phase",
        "evidence",
        "rule",
        "options",
        "decision",
        "rationale",
        "nextAction"
      ],
      "perPhaseRequired": true,
      "printRequired": true
    }
  },
  "runtimeAdapters": {
    "codexGoal": {
      "supported": true,
      "outerGoal": "Synchronize repository state while preserving Git safety gates and user-owned work.",
      "innerLoopAgent": "scm-sync-governor",
      "stateArtifact": "data/scm-sync/<projectId>/loop-state.json",
      "statusArtifact": "data/scm-sync/<projectId>/current-status.md",
      "evidenceRoot": "data/scm-sync/<projectId>/evidence/",
      "requiresFeature": "goals",
      "resumePolicy": "Resume only after git status, branch, and remote refs are re-inspected."
    },
    "shellRunner": {
      "supported": true,
      "stateArtifact": "data/scm-sync/<projectId>/loop-state.json"
    }
  },
  "validation": {
    "requiredSections": [
      "Toolkit-Wide Production Release Rule",
      "Defaults",
      "Goal-Driven Loop Mode",
      "Branch And Change Request Discipline",
      "Required Confirmations",
      "Standard Inspection",
      "Final Report",
      "Loop Goal Window",
      "Release Coverage Matrix Loop",
      "Production Representative Sandbox"
    ],
    "requiredPhrases": [
      "octopus-sandbox",
      "Never run `git reset --hard`",
      "Push only when requested",
      "loopState",
      "stopCondition",
      "Smoke checks may prove connectivity only",
      "NO-GO",
      "product-native release evidence",
      "finalGoal",
      "phaseGoals",
      "acceptanceCriteria",
      "finalDecision",
      "coverageMatrix",
      "evidenceMap",
      "repairPolicy",
      "releaseDecision",
      "repeated blocker",
      "decisionChain",
      "per-phase decision chain",
      "阶段决策链",
      "Production Representative Sandbox",
      "production-representative/manifest.json",
      "real target-product registration"
    ]
  }
}
