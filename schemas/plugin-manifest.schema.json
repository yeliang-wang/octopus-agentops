{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://octopus-agentops.local/schemas/plugin-manifest.schema.json",
  "title": "agent-octopus plugin manifest",
  "type": "object",
  "required": [
    "schema",
    "id",
    "version",
    "lifecycle",
    "category",
    "title",
    "description",
    "agents",
    "installTargets",
    "qualityGates"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "agent-octopus-plugin/v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "lifecycle": {
      "type": "string",
      "enum": ["experimental", "beta", "production-ready"]
    },
    "category": {
      "type": "string",
      "minLength": 3
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "installTargets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["claude-code", "codex"]
      }
    },
    "qualityGates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    }
  }
}
